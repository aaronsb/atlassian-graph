# Atlassian API credentials
# Get your API token from: https://id.atlassian.com/manage-profile/security/api-tokens
ATLASSIAN_EMAIL=your-email@example.com
ATLASSIAN_API_TOKEN=your-api-token-here

# Site Configuration
# Single site example:
ATLASSIAN_SITE=https://yourcompany.atlassian.net

# Multiple sites example (comma-separated):
# ATLASSIAN_SITE=https://site1.atlassian.net,https://site2.atlassian.net

# Default site (optional, will use first site if not specified)
ATLASSIAN_DEFAULT_SITE=yourcompany.atlassian.net

# Tool Class Configuration
# Enable/disable tool classes aligned with Atlassian's System of Work
# Set to true/false to toggle each class
ENABLE_FOUNDATIONAL_TOOLS=true
ENABLE_AI_INTELLIGENCE=true
ENABLE_SPECIALIZED_SOLUTIONS=true
ENABLE_TEAMWORK_GRAPH=true
ENABLE_MARKETPLACE_ECOSYSTEM=false
ENABLE_ADMINISTRATION=false
ENABLE_COLLABORATION=true

# Tool Generation Limits
MAX_TOOLS_PER_CLASS=15
TOTAL_MAX_TOOLS=50