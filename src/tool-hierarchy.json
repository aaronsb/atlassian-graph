{
  "version": "1.0.0",
  "description": "Hierarchical tool mapping to reduce 500+ generated tools to a manageable set",
  "topLevelTools": {
    "jira": {
      "name": "jira",
      "description": "Jira issue tracking and project management",
      "category": "core_products",
      "subTools": {
        "search": ["search-jira", "search-issue-search-views-by-ids", "search-field-schemes"],
        "get": ["get-jira", "get-issues-by-ids", "get-project-by-id-or-key", "get-board-view"],
        "list": ["list-field-schemes", "list-creatable-global-custom-field-types"],
        "manage": ["update-field-schemes", "create-field-scheme-associated-fields"]
      },
      "priority": 1
    },
    "confluence": {
      "name": "confluence",
      "description": "Confluence documentation and knowledge management",
      "category": "core_products",
      "subTools": {
        "search": ["search-core-products", "search-content-access-request-by-status", "search-user"],
        "get": ["get-confluence", "get-contents", "get-content-reactions-summary", "get-pdf-export-task"],
        "list": ["list-topics", "list-user-classes"],
        "manage": ["update-content-access-request-by-status", "create-content-reactions-summary"]
      },
      "priority": 1
    },
    "devops": {
      "name": "devops",
      "description": "Development and DevOps tools integration",
      "category": "development_devops",
      "subTools": {
        "search": ["search-dev-ops-services", "search-dev-ops-service-relationships-for-repository"],
        "get": ["get-dev-ops", "get-dev-ops-service", "get-development-information"],
        "list": ["list-dev-ops-services", "list-dev-ops-service-types"],
        "manage": ["update-dev-ops-service", "create-dev-ops-service-relationship"]
      },
      "priority": 2
    },
    "ai": {
      "name": "ai",
      "description": "AI and automation features",
      "category": "ai_intelligence",
      "subTools": {
        "agents": ["search-agent-studio-get-agents", "get-agent-studio-agent-by-id"],
        "devai": ["search-devai-autodev-jobs-for-issue", "get-devai-autodev-job-logs"],
        "convoai": ["search-convoai-jira-similar-work-items", "get-convoai-jira-related-resources-suggestions"],
        "intent": ["search-intentdetection-get-intent", "get-a-i-config"]
      },
      "priority": 3
    },
    "search": {
      "name": "search",
      "description": "Cross-product search and discovery",
      "category": "search_discovery",
      "subTools": {
        "primary": ["search-search-discovery", "search-nlp-search"],
        "knowledge": ["search-knowledge-base-search-articles", "search-help-object-store-search-articles"],
        "projects": ["search-projects-search"]
      },
      "priority": 2
    },
    "analytics": {
      "name": "analytics",
      "description": "Analytics and insights",
      "category": "analytics_insights",
      "subTools": {
        "content": ["get-content-analytics-views", "get-content-analytics-viewers"],
        "insights": ["get-polaris-insights", "get-insights"],
        "metrics": ["search-radar-group-metrics", "get-mercury-strategic-events"]
      },
      "priority": 4
    },
    "admin": {
      "name": "admin",
      "description": "Administration and configuration",
      "category": "administration",
      "subTools": {
        "org": ["get-org-policy-policy-details", "get-organization", "get-tenant"],
        "site": ["get-site-settings", "update-site-settings"],
        "security": ["get-classification-level", "update-classification-level"]
      },
      "priority": 5
    }
  },
  "toolSelectionRules": {
    "maxToolsPerCategory": 10,
    "defaultVerbs": ["search", "get", "list"],
    "priorityVerbs": {
      "search": 1,
      "get": 2,
      "list": 3,
      "create": 4,
      "update": 5,
      "delete": 6
    },
    "excludePatterns": [
      ".*-by-ids$",
      ".*-by-aris$",
      ".*-metadata-.*",
      ".*-diff-.*"
    ]
  },
  "dynamicToolMapping": {
    "enableDynamic": true,
    "fallbackBehavior": "useTopLevel",
    "expansionStrategy": "onDemand"
  }
}