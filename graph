#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")"

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

usage() {
  cat <<EOF
Usage: ./graph <command>

Commands:
  fetch       Fetch the Atlassian introspection schema and cache it locally
              (writes introspection-schema.json, ~30MB, gitignored)
  dev         Run Express (API, port 4000) and Vite (UI, port 5173) in the
              foreground. Ctrl+C stops both. Auto-fetches the schema on first
              run if missing.
  api         Run only the Express API server (useful for headless curl work).
  help        Show this message

Requires ATLASSIAN_EMAIL and ATLASSIAN_API_TOKEN in .env.
EOF
}

require_env() {
  if [ ! -f .env ]; then
    echo -e "${RED}Error: .env file not found.${NC}" >&2
    echo "Copy .env.example to .env and fill in ATLASSIAN_EMAIL + ATLASSIAN_API_TOKEN." >&2
    exit 1
  fi
  if ! grep -q '^ATLASSIAN_EMAIL=' .env || ! grep -q '^ATLASSIAN_API_TOKEN=' .env; then
    echo -e "${RED}Error: ATLASSIAN_EMAIL and ATLASSIAN_API_TOKEN must be set in .env.${NC}" >&2
    exit 1
  fi
}

ensure_schema() {
  if [ ! -f introspection-schema.json ]; then
    echo -e "${YELLOW}introspection-schema.json not found — fetching first…${NC}"
    node fetch-introspection.js
  fi
}

ensure_explorer_deps() {
  if [ ! -d explorer/node_modules ]; then
    echo -e "${YELLOW}Installing explorer dependencies…${NC}"
    (cd explorer && npm install)
  fi
}

cmd="${1:-help}"

case "$cmd" in
  fetch)
    require_env
    echo -e "${GREEN}Fetching introspection schema…${NC}"
    exec node fetch-introspection.js
    ;;
  api)
    require_env
    ensure_schema
    echo -e "${GREEN}API:${NC} http://localhost:${EXPLORER_PORT:-4000}/"
    echo "(Ctrl+C to stop)"
    echo ""
    exec node explorer-server.js
    ;;
  dev)
    require_env
    ensure_schema
    ensure_explorer_deps

    echo -e "${GREEN}API:${NC}      http://localhost:${EXPLORER_PORT:-4000}/"
    echo -e "${GREEN}Explorer:${NC} http://localhost:5173/"
    echo "(Ctrl+C stops both)"
    echo ""

    # kill 0 sends the signal to the whole process group, taking down
    # both children when this script exits or receives Ctrl+C.
    trap 'echo; echo "Stopping…"; kill 0' EXIT INT TERM

    node explorer-server.js &
    (cd explorer && node_modules/.bin/vite --port 5173) &

    wait
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    echo -e "${RED}Unknown command: $cmd${NC}" >&2
    echo "" >&2
    usage >&2
    exit 1
    ;;
esac
